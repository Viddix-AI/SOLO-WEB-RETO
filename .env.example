# ─────────────────────────────────────────────────────────────────────────────
# RETO portal — environment variables
# Copy this file to .env.local and fill in your SANDBOX values.
# .env.local is gitignored — never commit real secrets. The .pem private key is
# also gitignored (*.pem) — never commit it and never expose it to the client.
# ─────────────────────────────────────────────────────────────────────────────

# Amazon Pay (Checkout v2) — SANDBOX. Credentials are PER REGION. If a region's
# credentials are missing, that region's book checkout falls back to "Coming
# soon" (no crash). LATAM is ALWAYS "Coming soon" (Amazon Pay does not operate
# there), so it needs no variables.
#
# Where: Amazon Pay / Seller Central (sandbox) → Integration → Central /
# "API keys (MWS/Checkout v2)": create a Public/Private key pair (download the
# .pem private key and copy the Public Key ID). MERCHANT_ID = your Merchant/
# Seller ID. STORE_ID = the Checkout v2 Store ID (amzn1.application-oa2-client...).

AMAZON_PAY_SANDBOX=true

# ── US account (enables /us book checkout) ──
AMAZON_PAY_US_MERCHANT_ID=
AMAZON_PAY_US_STORE_ID=
AMAZON_PAY_US_PUBLIC_KEY_ID=
# PEM contents (single line with \n) OR a path to the .pem file (server-only, gitignored)
AMAZON_PAY_US_PRIVATE_KEY=

# ── EU account (enables /eu book checkout) ──
AMAZON_PAY_EU_MERCHANT_ID=
AMAZON_PAY_EU_STORE_ID=
AMAZON_PAY_EU_PUBLIC_KEY_ID=
AMAZON_PAY_EU_PRIVATE_KEY=

# ── LATAM: no variables — Amazon Pay is not available, always "Coming soon". ──


# ─────────────────────────────────────────────────────────────────────────────
# QuickBooks Online (Intuit) — OAuth2, SANDBOX first. QBO is the system of record
# for chamber concierge leads (no own DB). Get these from the Intuit Developer
# portal (https://developer.intuit.com): create/open your app → "Keys & OAuth".
# Use the app's DEVELOPMENT (sandbox) keys.
# ─────────────────────────────────────────────────────────────────────────────
QBO_ENVIRONMENT=sandbox
# App's sandbox OAuth keys (Keys & credentials → Development):
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
# Must EXACTLY match a Redirect URI registered on the app (Keys & OAuth → Redirect URIs),
# e.g. https://<your-https-host>/api/quickbooks/callback (https required; use a tunnel locally)
QBO_REDIRECT_URI=
# Webhooks → "Verifier token" (used to validate the intuit-signature header)
QBO_WEBHOOK_VERIFIER_TOKEN=

# Owner notification (lead safety net). If unset, leads are logged server-side.
# Resend: https://resend.com → API Keys.
RESEND_API_KEY=
OWNER_EMAIL=
RESEND_FROM_EMAIL=

