# ─────────────────────────────────────────────────────────────────────────────
# RETO portal — environment variables
# Copy this file to .env.local and fill in your TEST/SANDBOX values.
# .env.local is gitignored — never commit real secrets. The secret + webhook keys
# are server-only; only NEXT_PUBLIC_* values may reach the browser.
# ─────────────────────────────────────────────────────────────────────────────

# Stripe — book checkout (TEST mode). One Stripe account covers all three
# regions (US/LATAM charge in USD, EU in EUR); there is no per-region config.
# Make sure the Dashboard toggle is set to "Test mode" before copying these keys.
#
# Where (Stripe Dashboard, https://dashboard.stripe.com, Test mode ON):
#   • Secret + publishable key: Developers → API keys.
#       - Publishable key → NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY (pk_test_…, safe in the browser)
#       - Secret key       → STRIPE_SECRET_KEY (sk_test_…, server-only — never expose)
#   • Webhook signing secret: Developers → Webhooks → "Add endpoint" pointing to
#     https://<your-https-host>/api/stripe/webhook, subscribe to the
#     "payment_intent.succeeded" event, then copy the endpoint's "Signing secret"
#     → STRIPE_WEBHOOK_SECRET (whsec_…). Locally, run
#     `stripe listen --forward-to localhost:3000/api/stripe/webhook` and use the
#     whsec_… it prints.

# Publishable key — exposed to the browser (pk_test_…)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Secret key — server-only (sk_test_…)
STRIPE_SECRET_KEY=
# Webhook signing secret (whsec_…)
STRIPE_WEBHOOK_SECRET=


# ─────────────────────────────────────────────────────────────────────────────
# QuickBooks Online (Intuit) — OAuth2, SANDBOX first. QBO is the system of record
# for chamber concierge leads (no own DB). Get these from the Intuit Developer
# portal (https://developer.intuit.com): create/open your app → "Keys & OAuth".
# Use the app's DEVELOPMENT (sandbox) keys.
# ─────────────────────────────────────────────────────────────────────────────
QBO_ENVIRONMENT=sandbox
# App's sandbox OAuth keys (Keys & credentials → Development):
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
# Must EXACTLY match a Redirect URI registered on the app (Keys & OAuth → Redirect URIs),
# e.g. https://<your-https-host>/api/quickbooks/callback (https required; use a tunnel locally)
QBO_REDIRECT_URI=
# Webhooks → "Verifier token" (used to validate the intuit-signature header)
QBO_WEBHOOK_VERIFIER_TOKEN=

# Owner notification (lead safety net). If unset, leads are logged server-side.
# Resend: https://resend.com → API Keys.
RESEND_API_KEY=
OWNER_EMAIL=
RESEND_FROM_EMAIL=

